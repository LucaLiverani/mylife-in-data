# Copy to .env.development (gitignored, chmod 600) and fill in real values.
# Production secrets live in Cloudflare Pages → Settings → Environment variables.
#
# The CLICKHOUSE_* values here must match the ones in infrastructure/.env so
# the local Pages Functions can authenticate against the local ClickHouse.

CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=<set-username>
CLICKHOUSE_PASSWORD=<set-password>
CLICKHOUSE_DATABASE=gold

# Optional — used by the polling endpoint when a Redpanda producer exists.
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC=spotify.player.current
