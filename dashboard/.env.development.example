# Local-dev template — copy to .env.development (gitignored, chmod 600) and fill in.
# Production secrets live in dashboard/.env.production (also gitignored) and are
# uploaded to Cloudflare Pages by scripts/deploy-to-pages.sh.
#
# CLICKHOUSE_* values must match infrastructure/.env on the same machine so local
# Pages Functions can authenticate against the local ClickHouse.

# ── ClickHouse connection ──────────────────────────────────────────────────
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=<set-username>
CLICKHOUSE_PASSWORD=<set-password>
CLICKHOUSE_DATABASE=gold

# ── Cloudflare Access service token (prod only — leave commented in dev) ───
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# ── Kafka/Redpanda polling (optional) ──────────────────────────────────────
# Used by the polling endpoint when a Redpanda producer exists.
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC=spotify.player.current
