# Copy this to ~/.dbt/profiles.yml or to transformations/profiles.yml.
# Auto-mode generates a real profiles.yml at first dbt run by substituting
# env values from infrastructure/.env. Keep this example committed.

mylife:
  target: dev
  outputs:
    dev:
      type: clickhouse
      schema: default            # dbt's default schema; models override per layer
      host: "{{ env_var('CLICKHOUSE_HOST', 'clickhouse') }}"
      port: "{{ env_var('CLICKHOUSE_HTTP_PORT', '8123') | int }}"
      user: "{{ env_var('CLICKHOUSE_USER', 'default') }}"
      password: "{{ env_var('CLICKHOUSE_PASSWORD', '') }}"
      secure: False
      driver: http
      threads: 4
