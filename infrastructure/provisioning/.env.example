# Deploy-time variables — sourced on your LAPTOP, not on the VM.
# Copy to .env (gitignored) and fill in:
#
#     cp .env.example .env
#     # edit .env
#     source .env
#
# Then every ssh/scp/cloudflared command below picks up $VM_IP / $DOMAIN / etc.
# Re-source the file in each new terminal session.

# ── VM access ──────────────────────────────────────────────────────────────
VM_IP=
VM_USER=                              # what you chose during SSH hardening (e.g. admin)
LOCAL_KEY=~/.ssh/id_ed25519           # private key on your laptop

# ── GitHub ─────────────────────────────────────────────────────────────────
GH_REPO=                              # git@github.com:<you>/mylife-in-data.git (bootstrap.sh sets up a dedicated SSH alias, so this becomes git@github-mylife-in-data:<you>/mylife-in-data.git)

# ── Cloudflare ─────────────────────────────────────────────────────────────
DOMAIN=                               # apex domain on Cloudflare, e.g. liverani.dev
TUNNEL_ID=                            # UUID printed by `cloudflared tunnel create mylife-data` (Phase 3.1)
