# Copy to .env (gitignored, chmod 600) and fill in real values.
# Each compose subdirectory (clickhouse/, dagster/, monitoring/, redpanda/) has
# a `.env` symlink to this file, so any `docker compose` invocation finds the
# same values whether you use start-all.sh or cd into a subdir.
#
# Convention: one identity across the stack (ClickHouse user, Grafana admin,
# Dagster Postgres user all use the same username/password). Change to whatever
# you want — the stack reads everything from these vars.

# ── Identity (single user across the stack) ────────────────────────────────
CLICKHOUSE_USER=<set-username>
CLICKHOUSE_PASSWORD=<set-password>
GRAFANA_ADMIN_USER=<set-username>
GRAFANA_ADMIN_PASSWORD=<set-password>
DAGSTER_POSTGRES_USER=<set-username>
DAGSTER_POSTGRES_PASSWORD=<set-password>

# ── ClickHouse ─────────────────────────────────────────────────────────────
CLICKHOUSE_DB=default
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9200
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=default
# Scoped dev user for `dbt build --target dev` (dev_silver/dev_gold sandbox).
# Created by warehouse/ddl/bootstrap_dev_user.sh; read-only on prod layers.
CLICKHOUSE_DBT_DEV_USER=dbt_dev
CLICKHOUSE_DBT_DEV_PASSWORD=<set-password>

# ── Dagster ────────────────────────────────────────────────────────────────
DAGSTER_POSTGRES_DB=dagster
# Dagster UI binds to host:3000 by default. Uncomment + change if that
# DAGSTER_PORT=3030

# ── Redpanda ───────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
SCHEMA_REGISTRY_URL=http://redpanda:8081

# ── Spotify (Web API) ──────────────────────────────────────────────────────
# Register an app at https://developer.spotify.com/dashboard, then under
# "Redirect URIs" paste the value of SPOTIFY_REDIRECT_URI below verbatim.
# Note: Spotify deprecated `localhost` as a redirect host in late 2024 —
# use `127.0.0.1` explicitly (port can be anything free on the host).
SPOTIFY_CLIENT_ID=<from developer.spotify.com/dashboard>
SPOTIFY_CLIENT_SECRET=<from developer.spotify.com/dashboard>
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# ── R2 (Cloudflare object storage) — see IMPLEMENTATION_PLAN.md §1.3 ───────
# Account ID + Access Key + Secret + Bucket from R2 dashboard. Endpoint URL
# is "https://<account_id>.r2.cloudflarestorage.com".
R2_ACCOUNT_ID=<from-cloudflare-r2-dashboard>
R2_ACCESS_KEY_ID=<from-r2-api-tokens>
R2_SECRET_ACCESS_KEY=<from-r2-api-tokens>
R2_BUCKET=<bucket-name>
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Prune warehouse Parquet snapshots (archive/warehouse/dt=*) older than this
# many days. Runs after each nightly warehouse_r2_archive snapshot; 0 = keep forever.
R2_ARCHIVE_RETENTION_DAYS=30

# ── Google OAuth — see IMPLEMENTATION_PLAN.md §1.2 ─────────────────────────
# Create a Web Application OAuth client in Google Cloud Console with both
# the local laptop callback and the Pages re-auth callback as authorised
# redirect URIs. GOOGLE_REDIRECT_URI here is the Pages one (Dagster references
# it when crafting re-auth alert links).
GOOGLE_CLIENT_ID=<from-google-cloud-console>
GOOGLE_CLIENT_SECRET=<from-google-cloud-console>
GOOGLE_REDIRECT_URI=https://<pages-domain>/api/internal/google-auth-callback
GOOGLE_ACCOUNT_EMAIL=<your-google-account-email>
# Days before google_token_health raises an inactivity alert.
# 90 = production-app behaviour (no weekly re-auth). Drop to 6 if your GCP
# app stays in Testing publishing status.
GOOGLE_TOKEN_AGE_ALERT_DAYS=90

# Google Maps Platform — server-side API key (separate from OAuth credentials).
# Enables place type + neighborhood lookup for Maps activity entries.
# Set up: enable Places API + Geocoding API in GCP, create an API key in
# Credentials, restrict to those two APIs + your VM IP.
# Only used as a fallback when GEOCODER_PROVIDER=google or 'hybrid'.
GOOGLE_MAPS_API_KEY=<server-side-api-key>

# Geocoding provider for Maps place enrichment (text -> coords + neighborhood +
# place type). Default 'geoapify' (OpenStreetMap-based; free tier ~20k/mo;
# results cacheable under ODbL). Other values: 'google', 'hybrid'.
GEOCODER_PROVIDER=geoapify
# Geoapify API key — sign up at https://myprojects.geoapify.com (free tier).
# Required when GEOCODER_PROVIDER=geoapify or 'hybrid'.
GEOAPIFY_API_KEY=<geoapify-api-key>

# ── LLM (OpenAI-compatible) — Maps trip inference (Phase 5) ────────────────
# OpenAI-compatible chat-completions endpoint, used to adjudicate inferred trips
# (is-this-a-trip? + name/type/summary). LLM_API_BASE = resource/base URL,
# LLM_MODEL = model (or deployment) name. LLM_API_VERSION only for versioned
# endpoints (leave blank for vanilla OpenAI). A mini-class model is plenty here.
# Optional: MAPS_ENRICH_LIMIT overrides the per-run geocoding cap (default 200).
LLM_API_BASE=<openai-compatible-base-url>
LLM_API_KEY=<llm-api-key>
LLM_MODEL=<model-or-deployment-name>
LLM_API_VERSION=<api-version-if-required>

# ── Cloudflare Pages webhook secrets — see IMPLEMENTATION_PLAN.md §1.4 ─────
# Generate with `openssl rand -hex 32`. Same values go into
# dashboard/.env.production for the Pages Function side.
CALENDAR_WEBHOOK_TOKEN=<openssl-rand-hex-32>
GOOGLE_REAUTH_STATE_SECRET=<openssl-rand-hex-32>

# ── Laptop ↔ VM split flags ─────────────────────────────────────────────────
# The platform runs in two places: laptop (dev) and VM (prod). To keep OAuth
# refresh tokens coherent, exactly one of them is the writer.
#
# MYLIFE_TOKEN_WRITER         — when 1, google_oauth.load_and_refresh persists
#                                refreshed tokens back to auth.google_tokens
#                                and google_token_health writes auth.alerts
#                                rows. Set to 1 only on the VM.
# DAGSTER_SCHEDULES_ENABLED   — when 1, all Dagster schedules and sensors are
#                                registered, AND start-all.sh activates the
#                                `producer` compose profile so the continuous
#                                spotify-current-producer container runs. Set
#                                to 1 only on the VM.
#
# Laptop defaults (both 0) → schedules off, producer not started, refreshes
# happen in-memory but are never persisted; safe to pull tokens from VM
# on-demand via scripts/sync_tokens_from_vm.sh.
MYLIFE_TOKEN_WRITER=0
DAGSTER_SCHEDULES_ENABLED=0

# ── Deploy target (laptop only — used by `make deploy-vm`) ─────────────────
# VM_SSH = anything `ssh` can resolve. Easiest: add an entry to ~/.ssh/config
#   Host vm-alias
#       HostName <vm-ip-or-hostname>
#       User <vm-ssh-user>
#       IdentityFile ~/.ssh/id_ed25519
# then set VM_SSH=vm-alias here. Or use a literal `user@host`. Empty on the
# VM itself — it never deploys to itself.
VM_SSH=<ssh-config-alias-or-user@host>
VM_REPO_PATH=~/mylife-in-data

# ── Monitoring / alerting ───────────────────────────────────────────────────
# PLATFORM_ENV stamps Prometheus external_labels (and so alert email
# subjects) with where the alert fired: 'local' on the laptop, 'vm' on the VM.
PLATFORM_ENV=local
# ALERTING_ENABLED=1 starts Alertmanager (compose profile `alerting`); VM
# only. The laptop evaluates the same alert rules but has no delivery channel.
ALERTING_ENABLED=0
# Where Alertmanager delivers: the alert-mailer Worker (infrastructure/
# alert-mailer/, URL printed by `wrangler deploy`). The token is the same
# value stored in the Worker's ALERT_WEBHOOK_TOKEN secret (openssl rand -hex 32).
ALERT_WEBHOOK_URL=<https://alert-mailer.<subdomain>.workers.dev>
ALERT_WEBHOOK_TOKEN=<openssl-rand-hex-32>

# ── Umami (web analytics) ──────────────────────────────────────────────────
# Cookieless analytics for the dashboard. Runs its own Postgres (internal).
# APP_SECRET salts the visitor hash + signs sessions: `openssl rand -hex 32`,
# and never change it afterwards (rotating it invalidates sessions and shifts
# the visitor hash). UMAMI_PORT = host port for the UI (3000 = Dagster,
# 3001 = Grafana, so 3002 is the next free one).
UMAMI_POSTGRES_USER=<set-username>
UMAMI_POSTGRES_PASSWORD=<set-password>
UMAMI_POSTGRES_DB=umami
UMAMI_APP_SECRET=<openssl-rand-hex-32>
UMAMI_PORT=3002
